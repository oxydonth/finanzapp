generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  DEPOT
  LOAN
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SyncStatus {
  IDLE
  SYNCING
  SUCCESS
  FAILED
  TAN_REQUIRED
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  passwordHash        String
  firstName           String
  lastName            String
  currency            String           @default("EUR")
  locale              String           @default("de-DE")
  isEmailVerified     Boolean          @default(false)
  emailVerifyToken    String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  refreshTokenHash    String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  deletedAt           DateTime?

  bankConnections     BankConnection[]
  bankAccounts        BankAccount[]
  categories          Category[]
  budgets             Budget[]
  transactions        Transaction[]

  @@index([email])
  @@map("users")
}

model BankConnection {
  id                    String      @id @default(uuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  bankCode              String
  bankName              String
  fintsUrl              String
  fintsVersion          String      @default("300")

  loginNameEncrypted    String
  pinEncrypted          String
  pinIv                 String

  selectedTanMethod     String?
  availableTanMethods   Json?

  lastSyncAt            DateTime?
  syncStatus            SyncStatus  @default(IDLE)
  syncError             String?
  isActive              Boolean     @default(true)

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  accounts              BankAccount[]
  syncLogs              SyncLog[]

  @@index([userId])
  @@index([bankCode])
  @@map("bank_connections")
}

model BankAccount {
  id                    String         @id @default(uuid())
  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankConnectionId      String
  bankConnection        BankConnection @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)

  iban                  String
  ibanMasked            String
  bic                   String
  accountType           AccountType    @default(CHECKING)
  accountName           String
  ownerName             String
  currency              String         @default("EUR")

  balanceCents          BigInt         @default(0)
  balanceDate           DateTime?
  availableBalanceCents BigInt?

  isHidden              Boolean        @default(false)
  sortOrder             Int            @default(0)

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  transactions          Transaction[]
  budgets               Budget[]

  @@index([userId])
  @@index([bankConnectionId])
  @@map("bank_accounts")
}

model Category {
  id        String     @id @default(uuid())
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  icon      String?
  color     String?
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")

  isIncome  Boolean    @default(false)
  isSystem  Boolean    @default(false)
  sortOrder Int        @default(0)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  transactions  Transaction[]
  budgets       Budget[]
  rules         CategoryRule[]

  @@index([userId])
  @@map("categories")
}

model CategoryRule {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  pattern    String
  field      String   @default("purpose")
  priority   Int      @default(0)

  @@index([categoryId])
  @@map("category_rules")
}

model Transaction {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  externalId    String?
  valueDate     DateTime
  bookingDate   DateTime
  amountCents   BigInt
  currency      String      @default("EUR")
  type          TransactionType

  creditorName  String?
  creditorIban  String?
  creditorBic   String?

  purpose       String?
  mandateId     String?
  creditorId    String?
  endToEndId    String?

  merchantName      String?
  isRecurring       Boolean  @default(false)
  recurringGroupId  String?

  note          String?
  tags          String[]
  isReviewed    Boolean  @default(false)
  isPending     Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([bankAccountId, externalId])
  @@index([userId])
  @@index([bankAccountId])
  @@index([categoryId])
  @@index([bookingDate])
  @@map("transactions")
}

model Budget {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId    String
  category      Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)

  name           String
  limitCents     BigInt
  period         BudgetPeriod @default(MONTHLY)
  startDate      DateTime
  endDate        DateTime?
  rollover       Boolean      @default(false)
  alertThreshold Int          @default(80)
  isActive       Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@map("budgets")
}

model SyncLog {
  id               String         @id @default(uuid())
  bankConnectionId String
  bankConnection   BankConnection @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)

  startedAt           DateTime   @default(now())
  finishedAt          DateTime?
  status              SyncStatus
  transactionsFetched Int        @default(0)
  transactionsNew     Int        @default(0)
  errorMessage        String?

  @@index([bankConnectionId])
  @@map("sync_logs")
}
