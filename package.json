{
  "name": "finanzapp",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "turbo run db:migrate --filter=@finanzapp/api",
    "db:seed": "turbo run db:seed --filter=@finanzapp/api",
    "db:generate": "turbo run db:generate --filter=@finanzapp/api"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7"
  }
}
